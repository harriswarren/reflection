# Copy to .env or .env.local and fill in as needed.
# Brain API (Python FastAPI) — used by brainClient.ts
VITE_BRAIN_API_URL=http://localhost:8000

# Optional: TTS (Sesame / ElevenLabs)
# VITE_TTS_API_KEY=

# Optional: World Labs (Marble) — only if generating worlds from the frontend
# Prefer calling the Marble API from your Brain backend so the key is not in the client.
VITE_WORLDLABS_API_KEY=FdOIFfxK8ZVenoh9x4Os4p9zYGA128ic

# Optional: Splat URL for main world (default: /splats/tropical-island.spz)
# VITE_SPLAT_URL=/splats/tropical-island.spz
