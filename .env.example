# Copy to .env or .env.local and fill in as needed.

# Brain API (Python FastAPI) — used by brainClient.ts
VITE_BRAIN_API_URL=http://localhost:8000

# OpenAI API key — used by brain/main.py for GPT-4o-mini cognitive inference.
# Set this in your shell environment or in brain/.env
# OPENAI_API_KEY=sk-...

# Optional: TTS (Sesame / ElevenLabs)
# VITE_TTS_API_KEY=

# Optional: World Labs (Marble) — only if generating worlds from the frontend
# VITE_WORLDLABS_API_KEY=

# Optional: Splat URL for main world (default: /splats/Venice.spz)
# VITE_SPLAT_URL=/splats/Venice.spz
